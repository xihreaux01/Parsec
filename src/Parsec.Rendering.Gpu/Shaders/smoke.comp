#version 430 core

layout(local_size_x = 64) in;

layout(std430, binding = 0) buffer OutputBuffer {
    uint data[];
} outBuf;

void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx < outBuf.data.length()) {
        outBuf.data[idx] = idx * 2u + 1u;  // arbitrary deterministic pattern
    }
}
